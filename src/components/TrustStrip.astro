---
const items = [
  {
    title: 'Hecho a mano',
    desc: 'En pequeños lotes',
    icon: 'hand',
  },
  {
    title: '100% natural',
    desc: 'Sin aditivos raros',
    icon: 'leaf',
  },
  {
    title: 'Envío protegido',
    desc: 'Embalaje a prueba de golpes',
    icon: 'box',
  },
  {
    title: 'Atención humana',
    desc: 'Te acompañamos por WhatsApp',
    icon: 'chat',
  },
] as const;
---

<section class="section trust">
  <div class="wrap trust-grid" data-reveal-group data-reveal-step="90">
    {items.map((it) => (
      <div class="trust-item" data-reveal="rise">
        <span class="trust-ic" aria-hidden="true">
          {it.icon === 'hand' && (
            <svg viewBox="-24 -24 48 52" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M0,-3 C-3,-8 -11,-6 -11,0 C-11,5 -3,8 0,12 C3,8 11,5 11,0 C11,-6 3,-8 0,-3 Z"></path><path d="M-13,15 Q0,10 13,15"></path></svg>
          )}
          {it.icon === 'leaf' && (
            <svg viewBox="-24 -24 48 52" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M0,14 C-12,3 -12,-11 0,-16 C12,-11 12,3 0,14 Z"></path><path d="M0,14 L0,-13"></path></svg>
          )}
          {it.icon === 'box' && (
            <svg viewBox="-24 -24 48 52" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M-13,-6 L0,-13 L13,-6 L13,11 L-13,11 Z"></path><path d="M-13,-6 L0,0 L13,-6"></path><path d="M0,0 L0,11"></path></svg>
          )}
          {it.icon === 'chat' && (
            <svg viewBox="-24 -24 48 52" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M-15,-12 L15,-12 L15,6 L-6,6 L-13,13 L-13,6 L-15,6 Z"></path></svg>
          )}
        </span>
        <h3>{it.title}</h3>
        <p>{it.desc}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .trust {
    background: var(--verde);
    color: var(--on-dark);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.4rem;
  }
  .trust-item {
    text-align: center;
  }
  .trust-ic {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    margin: 0 auto 0.75rem;
    color: var(--crema);
  }
  .trust-ic svg {
    width: 38px;
    height: 38px;
    overflow: visible;
    transition: transform var(--dur) var(--ease-out);
  }
  .trust-item:hover .trust-ic svg {
    transform: translateY(-3px) scale(1.05);
  }
  .trust-item h3 {
    color: var(--crema);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.95rem;
    letter-spacing: var(--tracking-wide);
  }
  .trust-item p {
    font-size: 0.8rem;
    color: var(--on-dark-soft);
    margin-top: 0.25rem;
  }

  @media (max-width: 860px) {
    .trust-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem 1.4rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .trust-item:hover .trust-ic svg {
      transform: none;
    }
  }
</style>
