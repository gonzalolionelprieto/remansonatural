---
/**
 * Barra superior de anuncios. Los mensajes rotan suavemente (fade) y
 * respetan reduced-motion (se quedan quietos, mostrando el primero).
 */
const messages = [
  'Envíos a todo el país · 3 cuotas sin interés',
  '10% off pagando por transferencia',
  'Envío gratis en compras desde $85.000',
];
---

<div class="announce" role="region" aria-label="Anuncios de la tienda">
  <div class="announce-track" aria-live="off">
    {messages.map((m, i) => (
      <span class="announce-msg" style={`--i:${i}`}>{m}</span>
    ))}
  </div>
</div>

<style define:vars={{ count: 3 }}>
  .announce {
    background: var(--verde);
    color: var(--on-dark);
    font-size: var(--fs-eyebrow);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: center;
    height: 38px;
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .announce-track {
    position: relative;
    width: 100%;
    height: 1.2em;
  }

  .announce-msg {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding-inline: 1rem;
    opacity: 0;
    animation: announce-rotate calc(var(--count) * 4s) infinite;
    animation-delay: calc(var(--i) * 4s);
  }

  @keyframes announce-rotate {
    0%,
    2% {
      opacity: 0;
      transform: translateY(60%);
    }
    6%,
    30% {
      opacity: 1;
      transform: translateY(0);
    }
    34%,
    100% {
      opacity: 0;
      transform: translateY(-60%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .announce-msg {
      animation: none;
    }
    .announce-msg:first-child {
      opacity: 1;
    }
  }
</style>
