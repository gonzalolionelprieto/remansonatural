---
import Logo from './Logo.astro';
import AddToCartButton from './AddToCartButton.astro';
import Stars from './Stars.astro';
import { formatPrice } from '../lib/format';
import { lineaColor, lineaLabel, type Product } from '../lib/types';

interface Props {
  product: Product;
  /** umbral de envío gratis */
  envioGratisDesde?: number;
  /** animar al hacer scroll (Home). En el catálogo se desactiva. */
  reveal?: boolean;
}
const { product, envioGratisDesde = 85000, reveal = true } = Astro.props;
const {
  nombre,
  slug,
  linea,
  tipo,
  objetivos,
  precio,
  precioAnterior,
  volumen,
  descripcionCorta,
  imagenes = [],
  stock = 0,
  beneficios = [],
  reseñas = [],
} = product;
const avgRating =
  reseñas.length > 0
    ? reseñas.reduce((s, r) => s + r.estrellas, 0) / reseñas.length
    : 0;

const href = `/producto/${slug}`;
const img = imagenes[0];
const envioGratis = precio >= envioGratisDesde;
const sinStock = stock <= 0;
const sub = [volumen, descripcionCorta].filter(Boolean).join(' · ');
---

<article
  class="card"
  class:list={{ 'is-out': sinStock }}
  data-reveal={reveal ? 'rise' : undefined}
  data-product
  data-slug={slug}
  data-linea={linea}
  data-tipo={tipo}
  data-objetivos={objetivos.join(' ')}
  data-precio={precio}
  data-nombre={nombre.toLowerCase()}
  data-destacado={product.destacado ? '1' : '0'}
  data-orden={product.orden ?? 999}
>
  <a class="card-media" href={href} aria-label={nombre}>
    {sinStock ? (
      <span class="badge-out">Agotado</span>
    ) : (
      envioGratis && <span class="badge-free">Envío gratis</span>
    )}
    <span class="dot" style={`background:${lineaColor[linea]}`} aria-hidden="true"></span>
    {img ? (
      <img src={img} alt={nombre} width="600" height="600" loading="lazy" decoding="async" />
    ) : (
      <span class="ph" aria-hidden="true">
        <Logo size={54} stroke="var(--salvia)" accent="var(--tierra)" />
      </span>
    )}
  </a>

  <div class="card-body">
    <span class="card-line">{lineaLabel[linea]}</span>
    <h3><a href={href}>{nombre}</a></h3>
    {reseñas.length > 0 && (
      <p class="card-rating">
        <Stars value={avgRating} size={13} />
        <span>({reseñas.length})</span>
      </p>
    )}
    {sub && <p class="card-sub">{sub}</p>}
    {!sinStock && beneficios.length > 0 && (
      <>
        <button type="button" class="card-more" data-card-more aria-expanded="false">
          <span>Más</span>
          <svg class="card-more-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"></path></svg>
        </button>
        <div class="card-benefits-wrap">
          <ul class="card-benefits" role="list">
            {beneficios.slice(0, 3).map((b) => (
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 6"></path></svg>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      </>
    )}
    <p class="card-price">
      {precioAnterior && precioAnterior > precio && (
        <span class="card-price-old">{formatPrice(precioAnterior)}</span>
      )}
      <span class="card-price-now">{formatPrice(precio)}</span>
    </p>
    {sinStock ? (
      <a class="card-add is-disabled" href={href}>Ver producto</a>
    ) : (
      <AddToCartButton product={product} variant="solid" />
    )}
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    overflow: hidden;
    transition: transform var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }

  .card-media {
    position: relative;
    aspect-ratio: var(--img-aspect, 1 / 1);
    background: var(--crema-3);
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .card:hover .card-media img {
    transform: scale(1.05);
  }
  .ph {
    opacity: 0.5;
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .card:hover .ph {
    transform: scale(1.08) rotate(3deg);
  }

  .badge-free {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    z-index: 1;
    background: var(--verde);
    color: var(--crema);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
    border-radius: var(--r-pill);
  }
  .badge-out {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    z-index: 1;
    background: var(--carbon);
    color: var(--crema);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
    border-radius: var(--r-pill);
    opacity: 0.85;
  }
  .card.is-out .card-media .ph,
  .card.is-out .card-media img {
    filter: grayscale(0.4) opacity(0.75);
  }

  .dot {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    width: 12px;
    height: 12px;
    border-radius: var(--r-full);
    box-shadow: 0 0 0 3px var(--crema-3);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.1rem 1.1rem 1.2rem;
  }
  .card-line {
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--tierra);
  }
  .card h3 {
    font-size: var(--fs-h3);
    font-weight: 500;
    line-height: 1.18;
    margin: 0.3rem 0 0.15rem;
  }
  .card h3 a {
    transition: color var(--dur) var(--ease-out);
  }
  .card h3 a:hover {
    color: var(--tierra);
  }
  .card-sub {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .card-rating {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin: 0.3rem 0 0;
  }

  /* Toggle "Más" (solo mobile): despliega los beneficios ahí mismo, sin
     salir de la card. Desde tablet los beneficios ya están siempre visibles,
     así que el toggle se oculta y el bloque queda forzado abierto. */
  .card-more {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    align-self: flex-start;
    margin-top: 0.4rem;
    padding: 0;
    border: none;
    background: none;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--tierra);
    cursor: pointer;
  }
  .card-more-ic {
    width: 14px;
    height: 14px;
    transition: transform var(--dur) var(--ease-out);
  }
  .card.is-expanded .card-more-ic {
    transform: rotate(180deg);
  }

  .card-benefits-wrap {
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--dur) var(--ease-out);
  }
  .card.is-expanded .card-benefits-wrap {
    max-height: 220px; /* margen amplio: hasta 3 bullets de 2 líneas */
  }

  .card-benefits {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin: 0.6rem 0 0;
    font-size: 0.78rem;
    color: var(--text-soft);
  }
  .card-benefits li {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
  }
  .card-benefits svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--salvia);
  }
  @media (min-width: 640px) {
    .card-more {
      display: none;
    }
    .card-benefits-wrap {
      max-height: none;
      overflow: visible;
    }
  }

  .card-price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0.85rem 0;
  }
  .card-price-now {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--verde);
    font-variation-settings: 'opsz' 40;
  }
  .card-price-old {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: line-through;
  }

  .card-add {
    display: block;
    margin-top: auto;
    text-align: center;
    padding: 0.72rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--r-pill);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

</style>

<script>
  // Toggle "Más" (mobile): despliega los beneficios dentro de la misma card.
  // Delegación en document + flag para no duplicar el listener entre
  // navegaciones con ClientRouter (mismo patrón que CartDrawer.astro).
  let cardMoreBound = false;
  function initCardMore() {
    if (cardMoreBound) return;
    cardMoreBound = true;
    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-card-more]');
      if (!btn) return;
      const card = btn.closest('.card');
      if (!card) return;
      const expanded = card.classList.toggle('is-expanded');
      btn.setAttribute('aria-expanded', String(expanded));
    });
  }
  document.addEventListener('astro:page-load', initCardMore);
</script>
