---
import Logo from './Logo.astro';
import AddToCartButton from './AddToCartButton.astro';
import { formatPrice } from '../lib/format';
import { lineaColor, lineaLabel, type Product } from '../lib/types';

interface Props {
  product: Product;
  /** umbral de envío gratis */
  envioGratisDesde?: number;
  /** animar al hacer scroll (Home). En el catálogo se desactiva. */
  reveal?: boolean;
}
const { product, envioGratisDesde = 85000, reveal = true } = Astro.props;
const {
  nombre,
  slug,
  linea,
  tipo,
  objetivos,
  precio,
  volumen,
  descripcionCorta,
  imagenes = [],
  stock = 0,
} = product;

const href = `/producto/${slug}`;
const img = imagenes[0];
const envioGratis = precio >= envioGratisDesde;
const sinStock = stock <= 0;
const sub = [volumen, descripcionCorta].filter(Boolean).join(' · ');
---

<article
  class="card"
  class:list={{ 'is-out': sinStock }}
  data-reveal={reveal ? 'rise' : undefined}
  data-product
  data-slug={slug}
  data-linea={linea}
  data-tipo={tipo}
  data-objetivos={objetivos.join(' ')}
  data-precio={precio}
  data-nombre={nombre.toLowerCase()}
  data-destacado={product.destacado ? '1' : '0'}
  data-orden={product.orden ?? 999}
>
  <a class="card-media" href={href} aria-label={nombre}>
    {sinStock ? (
      <span class="badge-out">Agotado</span>
    ) : (
      envioGratis && <span class="badge-free">Envío gratis</span>
    )}
    <span class="dot" style={`background:${lineaColor[linea]}`} aria-hidden="true"></span>
    {img ? (
      <img src={img} alt={nombre} width="600" height="600" loading="lazy" decoding="async" />
    ) : (
      <span class="ph" aria-hidden="true">
        <Logo size={54} stroke="var(--salvia)" accent="var(--tierra)" />
      </span>
    )}
  </a>

  <div class="card-body">
    <span class="card-line">{lineaLabel[linea]}</span>
    <h3><a href={href}>{nombre}</a></h3>
    {sub && <p class="card-sub">{sub}</p>}
    <p class="card-price">{formatPrice(precio)}</p>
    {sinStock ? (
      <a class="card-add is-disabled" href={href}>Ver producto</a>
    ) : (
      <div class="card-add-wrap"><AddToCartButton product={product} /></div>
    )}
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    overflow: hidden;
    transition: transform var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }

  .card-media {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--crema-3);
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .card:hover .card-media img {
    transform: scale(1.05);
  }
  .ph {
    opacity: 0.5;
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .card:hover .ph {
    transform: scale(1.08) rotate(3deg);
  }

  .badge-free {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    z-index: 1;
    background: var(--verde);
    color: var(--crema);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
    border-radius: var(--r-pill);
  }
  .badge-out {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    z-index: 1;
    background: var(--carbon);
    color: var(--crema);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
    border-radius: var(--r-pill);
    opacity: 0.85;
  }
  .card.is-out .card-media .ph,
  .card.is-out .card-media img {
    filter: grayscale(0.4) opacity(0.75);
  }

  .dot {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    width: 12px;
    height: 12px;
    border-radius: var(--r-full);
    box-shadow: 0 0 0 3px var(--crema-3);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.1rem 1.1rem 1.2rem;
  }
  .card-line {
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--tierra);
  }
  .card h3 {
    font-size: var(--fs-h3);
    font-weight: 500;
    line-height: 1.18;
    margin: 0.3rem 0 0.15rem;
  }
  .card h3 a {
    transition: color var(--dur) var(--ease-out);
  }
  .card h3 a:hover {
    color: var(--tierra);
  }
  .card-sub {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .card-price {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--verde);
    margin: 0.85rem 0;
    font-variation-settings: 'opsz' 40;
  }

  .card-add-wrap {
    margin-top: auto;
  }
  .card-add {
    display: block;
    margin-top: auto;
    text-align: center;
    padding: 0.72rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--r-pill);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
</style>
