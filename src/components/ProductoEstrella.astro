---
import Logo from './Logo.astro';
import { formatPrice } from '../lib/format';
import { getCatalog } from '../lib/catalog';

interface Props {
  config?: { eyebrow?: string; titulo?: string; desc?: string; imagen?: string; slug?: string };
}
const c = Astro.props.config ?? {};
const slug = c.slug || 'doble-extracto-reishi';

const productos = await getCatalog();
const reishi = productos.find((p) => p.slug === slug) ?? productos[0];

const eyebrow = c.eyebrow || 'Producto estrella · Línea Alquimia';
const titulo = c.titulo || reishi.nombre;
const desc = c.desc || reishi.paraQueMomento || '';
const imagen = c.imagen || reishi.imagenes?.[0] || '';

// Los detalles salen de los beneficios del producto (los mismos que cargás en
// el panel y se ven en la card). Si todavía no tiene, mostramos su ficha
// técnica en vez de texto fijo que podría no corresponder al producto.
const detalles =
  reishi.beneficios && reishi.beneficios.length > 0
    ? reishi.beneficios
    : [reishi.volumen, reishi.graduacion].filter(Boolean);
---

<section class="section star">
  <div class="wrap star-row">
    <div class="star-visual" data-reveal="scale">
      {imagen ? (
        <img class="star-photo" src={imagen} alt={titulo} />
      ) : (
        <>
          <span class="star-ph" aria-hidden="true">
            <Logo size={92} stroke="var(--salvia)" accent="var(--tierra)" />
          </span>
          <span class="star-tag">Foto del gotero</span>
        </>
      )}
    </div>

    <div class="star-content" data-reveal="rise">
      <span class="eyebrow">{eyebrow}</span>
      <h2>{titulo}</h2>
      <p class="star-desc">{desc}</p>
      {detalles.length > 0 && (
        <ul class="star-list" data-reveal-group data-reveal-step="70">
          {detalles.map((d) => (
            <li data-reveal="rise">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 6"></path></svg>
              <span>{d}</span>
            </li>
          ))}
        </ul>
      )}
      <p class="star-price">{formatPrice(reishi.precio)}</p>
      <button
        class="btn btn-solid"
        type="button"
        data-add-to-cart
        data-slug={reishi.slug}
        data-nombre={reishi.nombre}
        data-precio={reishi.precio}
        data-linea={reishi.linea}
        data-stock={reishi.stock ?? 0}
      >
        Agregar al carrito
      </button>
    </div>
  </div>
</section>

<style>
  .star-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
  }

  .star-visual {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--r-lg);
    background:
      radial-gradient(80% 80% at 50% 35%, color-mix(in srgb, var(--salvia) 10%, transparent), transparent),
      var(--crema-2);
    border: 1px solid var(--border);
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .star-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .star-ph {
    opacity: 0.55;
    animation: rn-breathe 7s var(--ease-in-out) infinite;
  }
  .star-tag {
    position: absolute;
    bottom: 1rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .star h2 {
    margin-top: 0.5rem;
  }
  .star-desc {
    color: var(--text-soft);
    margin-top: 0.85rem;
    max-width: 46ch;
  }
  .star-list {
    list-style: none;
    margin: 1.2rem 0 1.5rem;
    display: grid;
    gap: 0.5rem;
  }
  /* Mismo tilde que las cards, para que el lenguaje visual sea uno solo. */
  .star-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.95rem;
    color: var(--text-soft);
  }
  .star-list li svg {
    width: 17px;
    height: 17px;
    flex-shrink: 0;
    margin-top: 0.2rem;
    color: var(--salvia);
  }
  .star-price {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 500;
    color: var(--tierra);
    margin-bottom: 1.15rem;
    font-variation-settings: 'opsz' 40;
  }

  @media (max-width: 860px) {
    .star-row {
      grid-template-columns: 1fr;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .star-ph {
      animation: none;
    }
  }
</style>
