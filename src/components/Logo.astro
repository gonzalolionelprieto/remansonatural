---
/**
 * Isotipo Remanso Natural: gota/hoja sobre tres ondas de agua concéntricas,
 * la del medio en color tierra. Recolorable vía props para fondos claros/oscuros.
 *
 * Cuando tengas el SVG oficial definitivo, reemplazá los <path> por el archivo
 * exportado (mantené el viewBox 0 0 96 108 para no tocar los tamaños).
 */
interface Props {
  size?: number;
  /** color de la gota y ondas exteriores */
  stroke?: string;
  /** color de la onda del medio (acento tierra por defecto) */
  accent?: string;
  /** anima el trazo al entrar (dibuja las líneas) */
  animated?: boolean;
  class?: string;
}

const {
  size = 34,
  stroke = 'var(--verde)',
  accent = 'var(--tierra)',
  animated = false,
  class: className = '',
} = Astro.props;

const h = Math.round((size * 108) / 96);
---

<svg
  width={size}
  height={h}
  viewBox="0 0 96 108"
  fill="none"
  aria-hidden="true"
  class:list={['rn-logo', { 'rn-logo--draw': animated }, className]}
>
  <path
    class="rn-logo-drop"
    d="M48,14 C56,30 56,40 48,47 C40,40 40,30 48,14 Z"
    stroke={stroke}
    stroke-width="2.4"
    stroke-linejoin="round"
  ></path>
  <path
    class="rn-logo-w1"
    d="M24,58 Q48,44 72,58"
    stroke={stroke}
    stroke-width="2.4"
    stroke-linecap="round"
  ></path>
  <path
    class="rn-logo-w2"
    d="M30,68 Q48,55 66,68"
    stroke={accent}
    stroke-width="2.4"
    stroke-linecap="round"
  ></path>
  <path
    class="rn-logo-w3"
    d="M37,77 Q48,69 59,77"
    stroke={stroke}
    stroke-width="2.4"
    stroke-linecap="round"
  ></path>
</svg>

<style>
  .rn-logo {
    overflow: visible;
  }

  /* Animación de "dibujo" opcional al entrar (hero / carga) */
  .rn-logo--draw path {
    stroke-dasharray: var(--len, 120);
    stroke-dashoffset: var(--len, 120);
    animation: rn-draw 1.1s var(--ease-out) forwards;
  }
  .rn-logo--draw .rn-logo-drop {
    --len: 160;
    animation-delay: 0.05s;
  }
  .rn-logo--draw .rn-logo-w1 {
    --len: 90;
    animation-delay: 0.45s;
  }
  .rn-logo--draw .rn-logo-w2 {
    --len: 75;
    animation-delay: 0.6s;
  }
  .rn-logo--draw .rn-logo-w3 {
    --len: 55;
    animation-delay: 0.72s;
  }

  @media (prefers-reduced-motion: reduce) {
    .rn-logo--draw path {
      stroke-dasharray: none;
      stroke-dashoffset: 0;
      animation: none;
    }
  }
</style>
