---
/**
 * Grilla tipo "bento" de categorías para la Home (inspirada en el diseño
 * importado y en referencias como Kaiken). Sin fotos todavía: paneles con
 * color de marca + patrón botánico de línea fina. Cuando haya fotos reales,
 * se reemplaza el fondo por background-image.
 */
interface PanelCfg { titulo?: string; sub?: string; imagen?: string; }
interface Props { panels?: PanelCfg[] }
const ov = Astro.props.panels ?? [];

const base = [
  { titulo: 'Extractos de hongos', sub: 'Reishi, Melena de León y más', href: '/tienda?tipo=extracto', area: 'a', bg: 'var(--verde)', bg2: 'var(--verde-900)' },
  { titulo: 'Encontrá tu calma', sub: 'Comprá por cómo te querés sentir', href: '/tienda?objetivo=calma', area: 'b', bg: 'var(--salvia)', bg2: '#5a7358' },
  { titulo: 'Flores de Bach', sub: 'Esencias para el día a día', href: '/tienda?tipo=esencia', area: 'c', bg: 'var(--linea-bach)', bg2: '#7d6b89' },
  { titulo: 'Humos & Ritual', sub: 'Sahumerios, siempre a mano', href: '/tienda?tipo=sahumerio', area: 'd', bg: 'var(--tierra)', bg2: '#8f6748' },
];
// Combina defaults con overrides del panel (por índice).
const panels = base.map((p, i) => ({
  ...p,
  titulo: ov[i]?.titulo || p.titulo,
  sub: ov[i]?.sub || p.sub,
  imagen: ov[i]?.imagen || '',
}));
---

<section class="section bento-sec">
  <div class="wrap">
    <div class="bento-head" data-reveal="rise">
      <span class="eyebrow">Explorá</span>
      <h2>Encontrá tu ritual</h2>
    </div>

    <div class="bento" data-reveal-group data-reveal-step="90">
      {panels.map((p) => (
        <a
          href={p.href}
          class:list={['panel', { 'has-photo': p.imagen }]}
          style={`--bg:${p.bg};--bg2:${p.bg2};grid-area:${p.area}`}
          data-reveal="scale"
        >
          {p.imagen && <img class="panel-photo" src={p.imagen} alt="" aria-hidden="true" />}
          <svg class="panel-pat" viewBox="0 0 200 200" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <defs>
              <g id={`leaf-${p.area}`}><path d="M0,16 C0,4 0,-8 0,-18" fill="none" stroke-width="1.2"></path><path d="M0,6 Q9,3 12,-6 Q3,-4 0,4 Z" fill="none" stroke-width="1.1"></path><path d="M0,-2 Q-9,-5 -12,-14 Q-3,-12 0,-4 Z" fill="none" stroke-width="1.1"></path></g>
              <pattern id={`pat-${p.area}`} width="80" height="80" patternUnits="userSpaceOnUse">
                <use href={`#leaf-${p.area}`} x="24" y="30" stroke="var(--crema)"></use>
                <use href={`#leaf-${p.area}`} x="64" y="66" stroke="var(--crema)"></use>
              </pattern>
            </defs>
            <rect width="200" height="200" fill={`url(#pat-${p.area})`}></rect>
          </svg>
          <div class="panel-body">
            <div>
              <h3>{p.titulo}</h3>
              <p>{p.sub}</p>
            </div>
            <span class="panel-cta">Ver más</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .bento-sec {
    background: var(--bg);
  }
  .bento-head {
    margin-bottom: clamp(1.5rem, 3vw, 2rem);
  }
  .bento-head h2 {
    margin-top: 0.4rem;
  }

  .bento {
    display: grid;
    grid-template-columns: 1fr 1.25fr 1.25fr;
    grid-template-rows: 1fr 1fr;
    grid-template-areas:
      'a b b'
      'a c d';
    gap: 14px;
    height: clamp(420px, 55vw, 600px);
  }

  .panel {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-lg);
    background: linear-gradient(150deg, var(--bg), var(--bg2));
    display: flex;
    align-items: flex-end;
    isolation: isolate;
    transition: transform var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .panel:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }
  .panel::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(30, 30, 30, 0.28), transparent 55%);
    z-index: 1;
  }
  .panel-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .panel.has-photo::after {
    background: linear-gradient(0deg, rgba(30, 30, 30, 0.62), rgba(30, 30, 30, 0.15) 55%);
  }
  .panel-pat {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.16;
    z-index: 0;
  }
  .panel.has-photo .panel-pat {
    display: none;
  }
  .panel-body {
    position: relative;
    z-index: 2;
    padding: clamp(1.25rem, 2.5vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
  }
  .panel h3 {
    font-family: var(--font-serif);
    color: var(--crema);
    font-size: clamp(1.35rem, 1rem + 1.6vw, 2.1rem);
    font-weight: 600;
    line-height: 1.05;
  }
  .panel p {
    color: rgba(244, 241, 234, 0.85);
    font-size: 0.9rem;
    margin-top: 0.35rem;
  }
  .panel-cta {
    align-self: flex-start;
    border: 1px solid rgba(244, 241, 234, 0.7);
    color: var(--crema);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.55rem 1.1rem;
    border-radius: var(--r-pill);
    transition: background var(--dur) var(--ease-out),
      color var(--dur) var(--ease-out);
  }
  .panel:hover .panel-cta {
    background: var(--crema);
    color: var(--carbon);
  }

  /* La primera (tall) alinea el contenido más arriba para respirar */
  .panel[style*='grid-area:a'] .panel-body {
    justify-content: flex-end;
  }

  @media (max-width: 760px) {
    .bento {
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        'a a'
        'b b'
        'c d';
      height: auto;
    }
    .panel {
      min-height: 200px;
    }
    .panel[style*='grid-area:a'] {
      min-height: 260px;
    }
  }
  @media (max-width: 440px) {
    .bento {
      grid-template-columns: 1fr;
      grid-template-areas: 'a' 'b' 'c' 'd';
    }
  }
</style>
