---
import Logo from './Logo.astro';
import { mainNav, site, objetivos, lineas, tipos } from '../lib/site';
import { getHomeConfig } from '../lib/catalog';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

// Contenido del mega-menú, editable desde el panel (Sitio → Mega-menú):
// foto del bloque destacado, su texto, y las bajadas de cada columna.
// Los links en sí (Por objetivo/línea/tipo) siguen saliendo de site.ts, no
// del panel: son las mismas categorías reales que filtran /tienda, y
// dejarlas como texto libre editable podría desincronizarlas del filtro.
const home = await getHomeConfig();
const mega = home?.mega ?? {};
const megaImagen: string = mega.imagen || '';
const megaTitulo: string = mega.titulo || 'Encontrá\ntu ritual';
const megaDesc: string = mega.desc || 'Rituales completos, armados a mano en pequeños lotes.';
const megaCta: string = mega.cta || 'Ver toda la tienda';
const megaTagObjetivo: string = mega.tagObjetivo || 'Según cómo te querés sentir';
const megaTagLinea: string = mega.tagLinea || 'Cada línea, su propio carácter';
const megaTagTipo: string = mega.tagTipo || 'Extractos, esencias, sahumerios';
---

<header class="site-header" data-header>
  <div class="wrap nav">
    <a class="brand" href="/" aria-label={`${site.name} — inicio`}>
      <Logo size={34} />
      <span class="brand-name">Remanso <i>Natural</i></span>
    </a>

    <nav class="menu" aria-label="Navegación principal">
      {mainNav.map((item) =>
        item.href === '/tienda' ? (
          <div class="menu-item has-mega">
            <a
              href={item.href}
              class="menu-link"
              aria-current={isActive(item.href) ? 'page' : undefined}
              aria-haspopup="true"
            >
              {item.label}
              <svg class="menu-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"></path></svg>
            </a>

            <div class="mega">
              <div class="mega-inner">
                <a class="mega-feature" href="/tienda">
                  {megaImagen ? (
                    <img class="mega-feature-photo" src={megaImagen} alt="" aria-hidden="true" />
                  ) : (
                    <span class="mega-feature-pattern" aria-hidden="true"></span>
                  )}
                  <span class="mega-feature-scrim" aria-hidden="true"></span>
                  <div class="mega-feature-body">
                    <span class="eyebrow">Explorá</span>
                    <h3>
                      {megaTitulo.split('\n').map((linea, i) => (
                        <>
                          {i > 0 && <br />}
                          {linea}
                        </>
                      ))}
                    </h3>
                    <p>{megaDesc}</p>
                  </div>
                  <span class="mega-feature-cta">
                    {megaCta}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
                  </span>
                </a>

                <div class="mega-cols">
                  <div class="mega-col">
                    <div class="mega-head">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="8.5"></circle><path d="M12 8.2l1.7 3.6 3.6.5-2.6 2.5.6 3.6-3.3-1.8-3.3 1.8.6-3.6-2.6-2.5 3.6-.5z"></path></svg>
                      <span>Por objetivo</span>
                    </div>
                    <p class="mega-tag">{megaTagObjetivo}</p>
                    <ul>
                      {objetivos.map((o) => (
                        <li><a href={`/tienda?objetivo=${o.slug}`}>{o.label}</a></li>
                      ))}
                    </ul>
                  </div>
                  <div class="mega-col">
                    <div class="mega-head">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21c-4-2.5-7-6-7-10.5A7 7 0 0 1 12 3a7 7 0 0 1 7 7.5C19 15 16 18.5 12 21z"></path><path d="M12 21V9"></path></svg>
                      <span>Por línea</span>
                    </div>
                    <p class="mega-tag">{megaTagLinea}</p>
                    <ul>
                      {lineas.map((l) => (
                        <li>
                          <a href={`/tienda?linea=${l.slug}`}>
                            <span class="mega-dot" style={`background:${l.color}`} aria-hidden="true"></span>
                            {l.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div class="mega-col">
                    <div class="mega-head">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 2.5h6l-.5 5.5 3.8 8a2 2 0 0 1-1.8 2.9H7.5a2 2 0 0 1-1.8-2.9l3.8-8z"></path><path d="M8.3 15h7.4"></path></svg>
                      <span>Por tipo</span>
                    </div>
                    <p class="mega-tag">{megaTagTipo}</p>
                    <ul>
                      {tipos.map((t) => (
                        <li><a href={`/tienda?tipo=${t.slug}`}>{t.label}</a></li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class="menu-link"
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        )
      )}
    </nav>

    <div class="nav-actions">
      <a class="icon-btn search-btn" href="/tienda#buscar" aria-label="Buscar en la tienda">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="M20 20l-3.2-3.2"></path></svg>
      </a>

      <button class="icon-btn cart-btn" type="button" aria-label="Ver carrito" data-cart-open>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 8h12l-1 12H7L6 8z"></path><path d="M9 8a3 3 0 0 1 6 0"></path></svg>
        <span class="cart-count" data-cart-count hidden>0</span>
      </button>

      <button
        class="icon-btn menu-toggle"
        type="button"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-menu-toggle
      >
        <span class="bars" aria-hidden="true"><span></span><span></span><span></span></span>
      </button>
    </div>
  </div>

  <!-- Menú móvil -->
  <div class="mobile-menu" id="mobile-menu" data-mobile-menu hidden>
    <nav aria-label="Navegación móvil">
      {mainNav.map((item, i) => (
        <a
          href={item.href}
          class="mobile-link"
          style={`--i:${i}`}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background: color-mix(in srgb, var(--crema) 92%, transparent);
    backdrop-filter: blur(10px) saturate(1.05);
    -webkit-backdrop-filter: blur(10px) saturate(1.05);
    border-bottom: 1px solid var(--border);
    transition: box-shadow var(--dur) var(--ease-out),
      background var(--dur) var(--ease-out);
  }
  /* Sombra suave sólo cuando el usuario bajó (data-scrolled lo setea el script) */
  .site-header[data-scrolled] {
    box-shadow: var(--shadow-sm);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 74px;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    flex-shrink: 0;
  }
  .brand-name {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--verde);
    font-variation-settings: 'opsz' 40;
    white-space: nowrap;
  }
  .brand-name i {
    font-style: italic;
    font-weight: 400;
  }
  .brand :global(.rn-logo) {
    transition: transform var(--dur) var(--ease-out);
  }
  .brand:hover :global(.rn-logo) {
    transform: rotate(-6deg) scale(1.06);
  }

  .menu {
    display: flex;
    align-items: center;
    align-self: stretch;
    gap: clamp(1rem, 2vw, 1.9rem);
    margin-inline: auto;
  }
  .menu-link {
    position: relative;
    font-size: 0.9rem;
    color: var(--text);
    padding-block: 0.4rem;
    transition: color var(--dur) var(--ease-out);
  }
  .menu-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1.5px;
    background: var(--tierra);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur) var(--ease-out);
  }
  .menu-link:hover,
  .menu-link[aria-current='page'] {
    color: var(--tierra);
  }
  .menu-link:hover::after,
  .menu-link[aria-current='page']::after {
    transform: scaleX(1);
  }

  /* Mega-menú de "Tienda": se abre con hover/foco, sin JS. `.menu-item`
     NO es el contenedor posicional del panel (a propósito, ver `.mega`
     más abajo) — sigue siendo el disparador del :hover, nada más.
     Ojo acá: `.menu-item` se estira a la altura completa del header
     (align-self: stretch, igual que `.menu`) para que no quede una franja
     sin hover entre el link y el panel — si no, al bajar el mouse en
     línea recta hacia `.mega` se sale del área hovereable antes de
     llegar, y el panel se cierra solo. */
  .menu-item {
    display: flex;
    align-items: center;
    align-self: stretch;
  }
  .menu-item .menu-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .menu-caret {
    width: 13px;
    height: 13px;
    transition: transform var(--dur) var(--ease-out);
  }
  .menu-item:hover .menu-caret,
  .menu-item:focus-within .menu-caret {
    transform: rotate(180deg);
  }

  /* El panel cuelga de .site-header (el ancestro posicionado más cercano,
     por su `position: sticky`), no de .menu-item — así `left:0; right:0`
     lo estira al ancho completo del header en vez de a una card angosta
     centrada bajo el link.

     Antes esto animaba con clip-path (efecto "cortina"), pero clip-path
     también recorta el área que recibe hover/click mientras dura la
     transición: si bajabas el mouse más rápido que la animación, salías
     de la porción todavía-no-revelada (que no cuenta como hover) antes de
     llegar al contenido, y el panel se cerraba solo a mitad de camino.
     Con opacity/visibility el tamaño real del panel está disponible para
     hover desde el primer frame, sin importar en qué punto va la
     transición visual — se puede "cortar camino" con el mouse sin que se
     cierre. */
  .mega {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--crema);
    border-top: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-6px);
    transition: opacity 0.28s var(--ease-out), transform 0.28s var(--ease-out),
      visibility 0.28s;
    z-index: 5;
  }
  .menu-item:hover .mega,
  .menu-item:focus-within .mega {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mega-inner {
    max-width: var(--maxw);
    margin-inline: auto;
    padding: 2.5rem var(--gutter) 2.75rem;
    display: grid;
    grid-template-columns: minmax(220px, 300px) repeat(3, 1fr);
    gap: clamp(1.75rem, 3vw, 3rem);
    /* Stagger sutil de entrada: el contenido sube+aparece un toque después
       de que el panel empieza a aparecer, no todo junto de golpe. Esta
       opacidad NO afecta el hover (a diferencia de clip-path, no recorta
       el área hovereable mientras anima). */
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.35s var(--ease-out) 0.05s,
      transform 0.35s var(--ease-out) 0.05s;
  }
  .menu-item:hover .mega-inner,
  .menu-item:focus-within .mega-inner {
    opacity: 1;
    transform: translateY(0);
  }

  /* -- Bloque destacado -- */
  .mega-feature {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    padding: 1.6rem;
    border-radius: var(--r-lg);
    background: var(--verde);
    color: var(--crema);
    transition: transform var(--dur) var(--ease-out);
  }
  .mega-feature:hover {
    transform: translateY(-3px);
  }
  .mega-feature-pattern {
    position: absolute;
    inset: -20% -30% auto auto;
    width: 70%;
    aspect-ratio: 1;
    background-image: repeating-linear-gradient(
      135deg,
      color-mix(in srgb, var(--crema) 14%, transparent) 0 1px,
      transparent 1px 14px
    );
    border-radius: var(--r-full);
    opacity: 0.55;
    pointer-events: none;
  }
  /* Foto opcional (panel): mismo lugar que la textura, a todo el bloque. */
  .mega-feature-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Veo siempre presente (con foto o sin ella) para que el texto se lea
     bien sobre cualquier imagen que se suba desde el panel. */
  .mega-feature-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      190deg,
      color-mix(in srgb, var(--verde) 55%, transparent) 0%,
      color-mix(in srgb, var(--verde) 88%, transparent) 100%
    );
    pointer-events: none;
  }
  .mega-feature-body {
    position: relative;
  }
  .mega-feature .eyebrow {
    color: var(--tierra);
  }
  .mega-feature-body h3 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.15;
    margin-top: 0.5rem;
    color: var(--crema);
    font-variation-settings: 'opsz' 40;
  }
  .mega-feature-body p {
    margin-top: 0.6rem;
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--crema) 80%, transparent);
    max-width: 24ch;
  }
  .mega-feature-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 1.5rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .mega-feature-cta svg {
    width: 16px;
    height: 16px;
    transition: transform var(--dur) var(--ease-out);
  }
  .mega-feature:hover .mega-feature-cta svg {
    transform: translateX(4px);
  }

  /* -- Columnas -- */
  .mega-cols {
    display: contents;
  }
  .mega-col {
    padding-top: 0.1rem;
  }
  .mega-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--verde);
  }
  .mega-head svg {
    width: 17px;
    height: 17px;
    color: var(--tierra);
    flex-shrink: 0;
  }
  .mega-tag {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin: 0.4rem 0 1.1rem;
  }
  .mega-col ul {
    display: grid;
    gap: 0.65rem;
    list-style: none;
    margin: 0;
    padding: 0.9rem 0 0;
    border-top: 1px solid var(--border);
  }
  .mega-col a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.89rem;
    color: var(--text-soft);
    transition: color var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
  }
  .mega-col a:hover {
    color: var(--verde);
    transform: translateX(3px);
  }
  .mega-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--r-full);
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .mega,
    .mega-inner,
    .menu-caret,
    .mega-feature,
    .mega-feature-cta svg,
    .mega-col a {
      transition: none;
    }
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
  }
  .icon-btn {
    display: inline-grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border: none;
    background: transparent;
    color: var(--verde);
    border-radius: var(--r-full);
    cursor: pointer;
    position: relative;
    transition: background var(--dur) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }
  .icon-btn:hover {
    background: rgba(47, 74, 58, 0.08);
  }
  .icon-btn:active {
    transform: scale(0.92);
  }
  .icon-btn svg {
    width: 22px;
    height: 22px;
  }

  .cart-count[hidden] {
    display: none;
  }
  .cart-count {
    position: absolute;
    top: 4px;
    right: 4px;
    min-width: 16px;
    height: 16px;
    padding-inline: 3px;
    border-radius: var(--r-full);
    background: var(--tierra);
    color: var(--crema);
    font-size: 10px;
    font-weight: 600;
    display: grid;
    place-items: center;
    line-height: 1;
  }

  /* Hamburguesa */
  .menu-toggle {
    display: none;
  }
  .bars {
    display: grid;
    gap: 4px;
  }
  .bars span {
    display: block;
    width: 20px;
    height: 1.8px;
    background: var(--verde);
    border-radius: 2px;
    transition: transform var(--dur) var(--ease-out),
      opacity var(--dur-fast) var(--ease-out);
  }
  [aria-expanded='true'] .bars span:nth-child(1) {
    transform: translateY(5.8px) rotate(45deg);
  }
  [aria-expanded='true'] .bars span:nth-child(2) {
    opacity: 0;
  }
  [aria-expanded='true'] .bars span:nth-child(3) {
    transform: translateY(-5.8px) rotate(-45deg);
  }

  /* Menú móvil desplegable */
  .mobile-menu {
    overflow: hidden;
    border-top: 1px solid var(--border);
    background: var(--crema);
  }
  .mobile-menu nav {
    display: flex;
    flex-direction: column;
    padding: 0.5rem var(--gutter) 1.25rem;
  }
  .mobile-link {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--verde);
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--border);
    opacity: 0;
    transform: translateY(-8px);
  }
  .mobile-menu:not([hidden]) .mobile-link {
    animation: rn-rise 0.45s var(--ease-out) forwards;
    animation-delay: calc(var(--i) * 60ms + 80ms);
  }
  .mobile-link[aria-current='page'] {
    color: var(--tierra);
  }

  @media (max-width: 860px) {
    .menu,
    .search-btn {
      display: none;
    }
    .menu-toggle {
      display: inline-grid;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu:not([hidden]) .mobile-link {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Header: sombra al hacer scroll. El listener global se registra una sola
  // vez; consulta el header actual en cada scroll (sobrevive a las
  // navegaciones con ClientRouter, donde el header se reemplaza).
  let scrollBound = false;
  const onScroll = () => {
    const header = document.querySelector<HTMLElement>('[data-header]');
    header?.toggleAttribute('data-scrolled', window.scrollY > 8);
  };

  // Bindings por elemento: se re-ejecutan en cada página (elementos nuevos).
  function initNav() {
    onScroll();
    if (!scrollBound) {
      scrollBound = true;
      window.addEventListener('scroll', onScroll, { passive: true });
    }

    const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    const panel = document.querySelector<HTMLElement>('[data-mobile-menu]');
    if (toggle && !toggle.dataset.bound) {
      toggle.dataset.bound = '1';
      toggle.addEventListener('click', () => {
        const open = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!open));
        toggle.setAttribute('aria-label', open ? 'Abrir menú' : 'Cerrar menú');
        panel?.toggleAttribute('hidden', open);
      });
    }
    if (panel && !panel.dataset.bound) {
      panel.dataset.bound = '1';
      panel.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('a')) {
          toggle?.setAttribute('aria-expanded', 'false');
          panel.setAttribute('hidden', '');
        }
      });
    }
  }

  document.addEventListener('astro:page-load', initNav);
</script>
