---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: 'center' | 'start';
}
const { eyebrow, title, lead, align = 'center' } = Astro.props;
---

<header class:list={['section-head', `is-${align}`]} data-reveal="rise">
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2>{title}</h2>
  {lead && <p class="lead">{lead}</p>}
</header>

<style>
  .section-head {
    margin-bottom: clamp(2rem, 1.5rem + 2vw, 2.9rem);
  }
  .is-center {
    text-align: center;
    max-width: 60ch;
    margin-inline: auto;
  }
  .section-head h2 {
    margin-top: 0.5rem;
  }
  .lead {
    color: var(--text-muted);
    max-width: 56ch;
    margin-top: 0.75rem;
    font-size: 0.97rem;
  }
  .is-center .lead {
    margin-inline: auto;
  }
</style>
