---
import { site } from '../lib/site';
const href = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(
  'Hola Remanso Natural 🌿 Quería consultar por...'
)}`;
---

<a
  class="wa-fab"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Escribinos por WhatsApp"
>
  <span class="wa-pulse" aria-hidden="true"></span>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M4 20l1.4-4A8 8 0 1 1 9 19.6L4 20z"></path>
    <path d="M9 9c0 3 3 6 6 6M9 9c0-1 1-1 1.5-.5l1 1.5-1 1M15 15c1 0 1-1 .5-1.5l-1.5-1-1 1"></path>
  </svg>
</a>

<style>
  .wa-fab {
    position: fixed;
    right: clamp(1rem, 3vw, 1.5rem);
    bottom: clamp(1rem, 3vw, 1.5rem);
    z-index: var(--z-fab);
    width: 54px;
    height: 54px;
    display: grid;
    place-items: center;
    border-radius: var(--r-full);
    background: var(--verde);
    color: var(--crema);
    box-shadow: var(--shadow-md);
    transition: transform var(--dur) var(--ease-out),
      background var(--dur) var(--ease-out);
  }
  .wa-fab svg {
    width: 27px;
    height: 27px;
    position: relative;
    z-index: 1;
  }
  .wa-fab:hover {
    transform: translateY(-3px) scale(1.05);
    background: var(--verde-900);
  }

  /* Anillo de pulso muy sutil, cada tanto, para llamar la atención sin gritar */
  .wa-pulse {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 2px solid var(--salvia);
    opacity: 0;
    animation: wa-pulse 4.5s var(--ease-out) infinite;
  }
  @keyframes wa-pulse {
    0% {
      transform: scale(1);
      opacity: 0.5;
    }
    18%,
    100% {
      transform: scale(1.7);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-pulse {
      animation: none;
    }
  }
</style>
