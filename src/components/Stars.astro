---
interface Props {
  value: number;
  size?: number;
}
const { value, size = 15 } = Astro.props;
const full = Math.round(value);
---

<span class="stars" role="img" aria-label={`${value} de 5 estrellas`}>
  {Array.from({ length: 5 }).map((_, i) => (
    <svg
      width={size}
      height={size}
      viewBox="0 0 24 24"
      fill={i < full ? 'var(--tierra)' : 'none'}
      stroke="var(--tierra)"
      stroke-width="1.4"
      aria-hidden="true"
    >
      <path d="M12 3l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.9 6.8 19.2l1-5.8L3.5 9.2l5.9-.9L12 3z"></path>
    </svg>
  ))}
</span>

<style>
  .stars {
    display: inline-flex;
    gap: 2px;
    vertical-align: middle;
  }
</style>
