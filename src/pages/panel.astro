---
// Panel de administración con preview en vivo. UI vía /api/panel.
---

<!doctype html>
<html lang="es-AR" style="color-scheme:dark;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Panel · Remanso Natural</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <!-- is:global → los estilos aplican también a los inputs/campos creados
         por JS (bloques del bento, widgets de imagen), que si no quedan sin
         estilo porque Astro scopea el <style> por defecto. -->
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: #1c2a22;
        color: #eef2ec;
        height: 100vh;
        overflow: hidden;
        -webkit-font-smoothing: antialiased;
      }

      a { color: #a87c5a; text-decoration: none; }
      h1 { font-size: 20px; font-weight: 600; }
      h2 { font-size: 15px; margin-bottom: 10px; color: #f4f1ea; }
      h3 { font-size: 12px; color: #6b8469; margin: 18px 0 6px; text-transform: uppercase; letter-spacing: .06em; font-weight: 600; }
      .muted { color: #9fb0a3; font-size: 13px; }

      /* ---- Inputs ---- */
      input, select, textarea {
        display: block;
        width: 100%;
        appearance: none;
        -webkit-appearance: none;
        background: #141f19 !important;
        border: 1.5px solid #3a4c40 !important;
        color: #eef2ec !important;
        border-radius: 8px;
        padding: 10px 13px;
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 14px;
        line-height: 1.4;
        margin-top: 5px;
        transition: border-color 0.2s, box-shadow 0.2s;
      }
      /* Anula autofill de Chrome/Edge que pone fondo amarillo/blanco */
      input:-webkit-autofill,
      input:-webkit-autofill:hover,
      input:-webkit-autofill:focus {
        -webkit-box-shadow: 0 0 0 1000px #141f19 inset !important;
        -webkit-text-fill-color: #eef2ec !important;
        caret-color: #eef2ec;
      }
      input[type="checkbox"] {
        display: inline-block;
        width: auto;
        accent-color: #6b8469;
        background: transparent !important;
        border: none !important;
      }
      input:focus, select:focus, textarea:focus {
        outline: none;
        border-color: #6b8469 !important;
        box-shadow: 0 0 0 3px rgba(107,132,105,.2);
      }
      textarea { min-height: 72px; resize: vertical; }
      label {
        display: block;
        font-size: 11.5px;
        font-weight: 500;
        color: #9fb0a3;
        margin-top: 14px;
        letter-spacing: .02em;
        text-transform: uppercase;
      }
      .field { margin-top: 4px; }

      /* ---- Buttons ---- */
      button {
        appearance: none;
        -webkit-appearance: none;
        border: none;
        background: none;
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 14px;
        cursor: pointer;
        line-height: 1;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #2f4a3a;
        color: #f4f1ea;
        border: 1.5px solid #2f4a3a;
        border-radius: 8px;
        padding: 10px 18px;
        font-weight: 500;
        cursor: pointer;
        transition: background .18s, transform .1s, box-shadow .18s;
      }
      .btn:hover { background: #3d6050; box-shadow: 0 3px 10px rgba(0,0,0,.3); }
      .btn:active { transform: translateY(1px); box-shadow: none; }
      .btn.ghost {
        background: transparent;
        color: #eef2ec;
        border-color: #3a4c40;
      }
      .btn.ghost:hover { background: rgba(255,255,255,.06); }
      .btn.danger {
        background: transparent;
        color: #c65b4e;
        border-color: #c65b4e;
      }
      .btn.danger:hover { background: rgba(198,91,78,.1); }
      .btn.sm { padding: 6px 12px; font-size: 12.5px; border-radius: 7px; }

      .row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
      .hidden { display: none !important; }
      .err { color: #c65b4e; font-size: 13px; min-height: 1em; margin-top: 8px; }

      /* ---- Login ---- */
      .login {
        max-width: 360px;
        margin: 14vh auto;
        background: #24352b;
        border: 1px solid #3a4c40;
        border-radius: 14px;
        padding: 32px 28px;
      }

      /* ---- Layout ---- */
      .app { display: grid; grid-template-columns: 470px 1fr; height: 100vh; }
      .editor { border-right: 1px solid #3a4c40; overflow-y: auto; padding: 22px; }
      .preview { background: #0f1712; position: relative; }
      .preview iframe { width: 100%; height: 100%; border: 0; background: #fff; }
      .preview .pv-bar { position: absolute; top: 10px; right: 12px; z-index: 2; }

      .header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; padding-bottom: 14px; border-bottom: 1px solid #3a4c40; }
      .tabs { display: flex; gap: 6px; margin-bottom: 18px; }
      .tab {
        background: transparent;
        border: 1.5px solid #3a4c40;
        color: #9fb0a3;
        border-radius: 999px;
        padding: 7px 16px;
        cursor: pointer;
        font-size: 13px;
        transition: all .18s;
      }
      .tab.active { background: #24352b; color: #f4f1ea; border-color: #6b8469; }
      .tab:hover:not(.active) { color: #eef2ec; border-color: #6b8469; }

      .list { display: grid; gap: 8px; }
      .item {
        display: flex;
        align-items: center;
        gap: 12px;
        background: #24352b;
        border: 1px solid #3a4c40;
        border-radius: 10px;
        padding: 10px 12px;
      }
      .item .thumb { width: 44px; height: 44px; border-radius: 8px; background: #1a271f; object-fit: cover; flex-shrink: 0; border: 1px solid #3a4c40; }
      .item .info { flex: 1; min-width: 0; }
      .item .name { font-weight: 500; font-size: 14px; }
      .card { background: #24352b; border: 1px solid #3a4c40; border-radius: 12px; padding: 18px; margin-bottom: 14px; }
      .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
      .chips { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; }
      .chip { border: 1.5px solid #3a4c40; border-radius: 999px; padding: 5px 12px; cursor: pointer; font-size: 12.5px; color: #9fb0a3; transition: all .15s; }
      .chip:hover { border-color: #6b8469; color: #eef2ec; }
      .chip.on { background: #2f4a3a; border-color: #2f4a3a; color: #f4f1ea; }

      /* ---- Widget imagen ---- */
      .imgw { margin-top: 8px; }
      .imgw .prev { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 8px; }
      .imgw figure { position: relative; }
      .imgw img { width: 72px; height: 72px; object-fit: cover; border-radius: 8px; border: 1px solid #3a4c40; display: block; }
      .imgw figure button {
        position: absolute; top: -6px; right: -6px;
        width: 20px; height: 20px; border-radius: 50%;
        background: #c65b4e; color: #fff;
        border: none; cursor: pointer; font-size: 12px;
        display: flex; align-items: center; justify-content: center;
      }
      .imgw .up { display: inline-block; font-size: 12.5px; color: #6b8469; cursor: pointer; border: 1.5px dashed #3a4c40; border-radius: 8px; padding: 8px 14px; transition: border-color .18s, color .18s; }
      .imgw .up:hover { border-color: #6b8469; color: #eef2ec; }
      .imgw input[type=file] { display: none !important; }

      .toast { position: fixed; bottom: 18px; left: 470px; margin-left: 20px; background: #2f4a3a; color: #f4f1ea; padding: 11px 18px; border-radius: 10px; opacity: 0; transition: opacity .3s; box-shadow: 0 8px 30px rgba(0,0,0,.4); z-index: 50; pointer-events: none; }
      .toast.show { opacity: 1; }

      @media (max-width: 900px) { .app { grid-template-columns: 1fr; } .preview { display: none; } .toast { left: 20px; } }
    </style>

  </head>
  <body>
    <!-- Login -->
    <div class="login" id="login">
      <h1>Panel · Remanso</h1>
      <p class="muted" style="margin:6px 0 0;">Ingresá la contraseña para administrar.</p>
      <label for="pass">Contraseña</label>
      <input id="pass" type="password" autocomplete="current-password" />
      <div class="err" id="loginErr"></div>
      <div class="row" style="margin-top:14px;"><button class="btn" id="loginBtn">Entrar</button></div>
    </div>

    <!-- App -->
    <div class="app hidden" id="app">
      <div class="editor">
        <div class="header">
          <div><h1>Remanso Natural</h1><span class="muted">Panel</span></div>
          <button class="btn ghost sm" id="logout">Salir</button>
        </div>
        <div class="tabs">
          <button class="tab active" data-tab="productos">Productos</button>
          <button class="tab" data-tab="sitio">Sitio (Home)</button>
          <button class="tab" data-tab="ventas">Ventas</button>
        </div>

        <!-- Productos -->
        <section id="tab-productos">
          <div class="row" style="justify-content:space-between;margin-bottom:12px;">
            <h2 style="margin:0;">Productos</h2>
            <button class="btn sm" id="nuevo">+ Nuevo</button>
          </div>
          <!-- Selector de plantilla -->
          <div class="card hidden" id="plantillas" style="margin-bottom:14px;">
            <h2>¿Qué vas a cargar?</h2>
            <p class="muted">Elegí una plantilla: te precarga los campos propios de ese tipo de producto.</p>
            <div class="chips" id="plantillasList" style="margin-top:12px;"></div>
          </div>

          <div class="list" id="lista"></div>

          <div class="card hidden" id="editorP" style="margin-top:14px;">
            <h2 id="editorTitle">Nuevo producto</h2>
            <div class="grid2">
              <div><label>Nombre</label><input id="f-nombre" /></div>
              <div><label>Slug</label><input id="f-slug" /></div>
              <div><label>Línea</label><select id="f-linea"><option value="alquimia">Alquimia</option><option value="bach">Flores de Bach</option><option value="humos">Humos & Ritual</option><option value="cristales">Cristales</option></select></div>
              <div><label>Tipo</label><select id="f-tipo"><option value="extracto">Extracto de hongos</option><option value="esencia">Esencia floral</option><option value="sahumerio">Sahumerio</option><option value="cristal">Cristal</option><option value="kit">Kit</option></select></div>
              <div><label>Precio (ARS)</label><input id="f-precio" type="number" /></div>
              <div><label>Stock</label><input id="f-stock" type="number" /></div>
              <div><label>Volumen / medidas</label><input id="f-volumen" placeholder="50 ml" /></div>
              <div><label>Graduación</label><input id="f-graduacion" /></div>
              <div><label>Orden</label><input id="f-orden" type="number" /></div>
              <div style="display:flex;align-items:flex-end;"><label style="margin:0;display:flex;gap:8px;align-items:center;cursor:pointer;"><input id="f-destacado" type="checkbox" style="width:auto;" /> Destacado</label></div>
            </div>
            <label>Objetivos</label>
            <div class="chips" id="f-objetivos">
              <span class="chip" data-obj="calma">Calma</span><span class="chip" data-obj="sueno">Sueño</span>
              <span class="chip" data-obj="enfoque">Enfoque</span><span class="chip" data-obj="ritual">Ritual</span>
            </div>
            <label>Imágenes</label><div class="imgw" id="w-prod"></div>
            <label>Descripción corta</label><input id="f-descCorta" />
            <label>Para qué momento</label><textarea id="f-momento"></textarea>
            <label>Descripción larga</label><textarea id="f-descLarga"></textarea>
            <div class="grid2">
              <div><label>Ingredientes</label><textarea id="f-ingredientes"></textarea></div>
              <div><label>Modo de uso</label><textarea id="f-modo"></textarea></div>
              <div><label>Nuestro proceso</label><textarea id="f-proceso"></textarea></div>
              <div><label>Envío y cuidado</label><textarea id="f-envio"></textarea></div>
            </div>
            <label>Advertencias</label><textarea id="f-advertencias"></textarea>
            <label>Combiná con (slugs, coma)</label><input id="f-combina" />
            <div class="err" id="editorErr"></div>
            <div class="row" style="margin-top:14px;"><button class="btn" id="guardar">Guardar</button><button class="btn ghost" id="cancelar">Cancelar</button></div>
          </div>
        </section>

        <!-- Sitio -->
        <section id="tab-sitio" class="hidden">
          <div class="card">
            <h2>Fotos de producto</h2>
            <p class="muted">Relación de aspecto de TODAS las fotos de producto (miniaturas y ficha). Al subir una imagen se recorta sola a esta proporción.</p>
            <label>Formato</label>
            <select id="s-aspecto">
              <option value="1:1">Cuadrada 1:1 — clásica de e-commerce</option>
              <option value="4:5">Vertical 4:5 — estilo Instagram (recomendada)</option>
              <option value="3:4">Vertical 3:4 — un poco menos alta</option>
              <option value="9:16">Vertical 9:16 — bien alta, tipo story</option>
            </select>
            <p class="muted" style="margin-top:8px;">Si la cambiás, volvé a subir las fotos para que se recorten con el formato nuevo.</p>
          </div>

          <div class="card">
            <h2>Portada (Hero)</h2>
            <label>Etiqueta superior</label><input id="h-eyebrow" />
            <label>Título</label><input id="h-titulo" />
            <label>Palabra destacada</label><input id="h-destacada" />
            <label>Descripción</label><textarea id="h-lead"></textarea>
            <label>Foto de fondo (opcional)</label><div class="imgw" id="w-hero"></div>
            <div class="grid2">
              <div>
                <label>Velo sobre la foto (0–100)</label>
                <input id="h-overlay" type="number" min="0" max="100" placeholder="60" />
              </div>
              <div>
                <label>Desenfoque (px)</label>
                <input id="h-blur" type="number" min="0" max="30" placeholder="3" />
              </div>
            </div>
            <p class="muted" style="margin-top:6px;">Más velo = foto más suave detrás del texto. Recomendado: velo 60, desenfoque 3.</p>
          </div>

          <div class="card">
            <h2>Bloques de categorías (bento)</h2>
            <p class="muted">Cada bloque puede tener su foto.</p>
            <div id="bento-blocks"></div>
          </div>

          <div class="card">
            <h2>Producto estrella</h2>
            <label>Etiqueta</label><input id="e-eyebrow" />
            <label>Título</label><input id="e-titulo" />
            <label>Descripción</label><textarea id="e-desc"></textarea>
            <label>Foto</label><div class="imgw" id="w-estrella"></div>
          </div>

          <div class="err" id="sitioErr"></div>
          <button class="btn" id="guardarSitio">Guardar sitio</button>
        </section>

        <!-- Ventas -->
        <section id="tab-ventas" class="hidden">
          <div class="row" style="justify-content:space-between;margin-bottom:12px;">
            <h2 style="margin:0;">Ventas y Pedidos</h2>
            <button class="btn ghost sm" id="btn-refresh-ventas">↻ Actualizar</button>
          </div>
          <div class="list" id="lista-ventas"></div>
        </section>
      </div>

      <div class="preview">
        <div class="pv-bar"><button class="btn ghost sm" id="pvReload">↻ Recargar</button></div>
        <iframe id="pv" src="/"></iframe>
      </div>
    </div>

    <div class="toast" id="toast"></div>

    <script>
      // @ts-nocheck
      const $ = (s) => document.querySelector(s);
      const KEY = 'rn_panel_pass';
      let pass = sessionStorage.getItem(KEY) || '';
      let editSlugOriginal = null;
      let prodImgs = [];
      const objSel = new Set();
      let home = { hero: {}, bento: [{}, {}, {}, {}], estrella: {} };
      const BENTO_LABELS = ['Bloque 1 (grande, izquierda)', 'Bloque 2 (arriba)', 'Bloque 3', 'Bloque 4'];

      // Relación de aspecto de las fotos de producto (elegida en el panel).
      const ASPECT_NUM = { '1:1': 1, '4:5': 0.8, '3:4': 0.75, '9:16': 0.5625 };
      const prodAspect = () => ASPECT_NUM[home.imagenAspecto] ?? 1;

      // Plantillas por tipo de producto: precargan los campos propios de cada uno.
      const PLANTILLAS = [
        {
          label: '🍄 Extracto de hongo',
          d: {
            tipo: 'extracto', linea: 'alquimia', volumen: '50 ml', graduacion: '~25% Alc./Vol.',
            objetivos: ['calma'],
            descripcion_corta: 'Para tus momentos de calma',
            para_que_momento: 'Para esos días en que la mente no baja un cambio. Unas gotas en tu infusión, como un pequeño ritual.',
            ingredientes: 'Hongo entero deshidratado, alcohol de cereal, agua pura. Sin azúcares, sin conservantes.',
            modo_de_uso: '1 a 2 goteros (aprox. 1 ml) al día, solo o en tu infusión preferida. Agitá antes de usar.',
            nuestro_proceso: 'Doble extracción real: fase en alcohol con calor controlado y decocción lenta en agua. Unimos ambas fases y rotulamos cada lote.',
            envio_y_cuidado: 'Enviamos a todo el país en 24–72 h hábiles. Conservá en lugar fresco y seco, lejos de la luz directa.',
            advertencias: 'Producto de bienestar. No es un medicamento. Ante embarazo, lactancia o medicación, consultá a un profesional de la salud.',
          },
        },
        {
          label: '🌀 Blend de hongos',
          d: {
            tipo: 'extracto', linea: 'alquimia', volumen: '50 ml', graduacion: '~25% Alc./Vol.',
            objetivos: ['calma', 'enfoque'],
            descripcion_corta: 'Mezcla de hongos para el equilibrio',
            para_que_momento: 'Cuando querés lo mejor de varios hongos en un solo gesto. Un blend pensado para acompañar tu día.',
            ingredientes: 'Blend de hongos enteros deshidratados, alcohol de cereal, agua pura. Proporciones equilibradas.',
            modo_de_uso: '1 a 2 goteros (aprox. 1 ml) al día. Agitá antes de usar. Empezá con poco y encontrá tu dosis.',
            nuestro_proceso: 'Cada hongo se extrae por separado (alcohol + agua) y recién después se combinan en la proporción justa. Cada lote rotulado.',
            envio_y_cuidado: 'Enviamos a todo el país en 24–72 h hábiles. Conservá en lugar fresco y seco, lejos de la luz directa.',
            advertencias: 'Producto de bienestar. No es un medicamento. Ante embarazo, lactancia o medicación, consultá a un profesional de la salud.',
          },
        },
        {
          label: '🌸 Esencia floral (Bach)',
          d: {
            tipo: 'esencia', linea: 'bach', volumen: '30 ml', graduacion: '',
            objetivos: ['calma'],
            descripcion_corta: 'Flores de Bach para el día a día',
            para_que_momento: 'Para los momentos de tensión del día: antes de una reunión, en un viaje, o cuando necesitás un respiro.',
            ingredientes: 'Preparado de esencias florales (sistema del Dr. Bach), agua de manantial y brandy como conservante natural.',
            modo_de_uso: '4 gotas bajo la lengua o en un vaso de agua, hasta 4 veces al día. Podés repetir cuando lo sientas necesario.',
            nuestro_proceso: 'Preparada de forma artesanal siguiendo el método tradicional de las esencias florales, rotulada por lote.',
            envio_y_cuidado: 'Enviamos a todo el país en 24–72 h hábiles. Conservá lejos del calor y de la luz directa.',
            advertencias: 'Producto de bienestar. No es un medicamento. Contiene una pequeña proporción de brandy. Ante embarazo, lactancia o medicación, consultá a un profesional.',
          },
        },
        {
          label: '🔥 Sahumerio / Humos',
          d: {
            tipo: 'sahumerio', linea: 'humos', volumen: '', graduacion: '',
            objetivos: ['ritual'],
            descripcion_corta: 'Para tu ritual y tu espacio',
            para_que_momento: 'Para preparar tu rincón de calma. Encendelo, bajá las luces y date el permiso de una pausa.',
            ingredientes: 'Hierbas y resinas naturales seleccionadas, ligadas a mano. Sin fragancias sintéticas.',
            modo_de_uso: 'Encendé la punta, dejá que prenda unos segundos y apagá la llama. Colocalo en un soporte resistente al calor.',
            nuestro_proceso: 'Armado a mano en pequeños lotes, con materia prima seleccionada y secado natural.',
            envio_y_cuidado: 'Enviamos a todo el país en 24–72 h hábiles. Conservá en lugar seco.',
            advertencias: 'Producto de bienestar. No es un medicamento. Nunca dejes un sahumerio encendido sin supervisión. Mantener fuera del alcance de niños.',
          },
        },
      ];

      const toast = (m) => { const t = $('#toast'); t.textContent = m; t.classList.add('show'); setTimeout(() => t.classList.remove('show'), 2200); };
      const api = async (payload) => { const r = await fetch('/api/panel', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ password: pass, ...payload }) }); return { ok: r.ok, data: await r.json() }; };
      const reloadPreview = () => { const f = $('#pv'); try { f.contentWindow.location.reload(); } catch { f.src = '/?t=' + Date.now(); } };

      /**
       * Normaliza la imagen ANTES de subirla:
       *  - recorte centrado a la relación de aspecto del lugar donde va
       *    (así todas quedan iguales y no se rompe el diseño)
       *  - reescala a un ancho máximo y convierte a WebP (peso liviano)
       */
      async function processImage(file, aspect, maxW) {
        maxW = maxW || 1400;
        const bmp = await createImageBitmap(file);
        let sw = bmp.width, sh = bmp.height, sx = 0, sy = 0;
        if (aspect) {
          if (bmp.width / bmp.height > aspect) { sw = bmp.height * aspect; sx = (bmp.width - sw) / 2; }
          else { sh = bmp.width / aspect; sy = (bmp.height - sh) / 2; }
        }
        const outW = Math.min(maxW, Math.round(sw));
        const outH = Math.round(outW / (aspect || sw / sh));
        const c = document.createElement('canvas');
        c.width = outW; c.height = outH;
        const ctx = c.getContext('2d');
        ctx.imageSmoothingEnabled = true; ctx.imageSmoothingQuality = 'high';
        ctx.drawImage(bmp, sx, sy, sw, sh, 0, 0, outW, outH);
        const blob = await new Promise((r) => c.toBlob(r, 'image/webp', 0.82));
        if (!blob) return file; // navegador sin WebP → subimos el original
        const name = (file.name.replace(/\.[^.]+$/, '') || 'imagen') + '.webp';
        return new File([blob], name, { type: 'image/webp' });
      }

      async function uploadImage(file, aspect) {
        let f = file;
        try { f = await processImage(file, aspect); } catch { /* si falla, va el original */ }
        const fd = new FormData(); fd.append('password', pass); fd.append('file', f);
        const r = await fetch('/api/panel', { method: 'POST', body: fd });
        const d = await r.json();
        if (r.ok && d.url) return d.url;
        toast(d.error || 'Error al subir'); return null;
      }

      // Widget de imagen. multiple = varias (productos). aspect = relación de aspecto destino.
      function imgWidget(el, getArr, setArr, multiple, aspect, hint) {
        function render() {
          const arr = getArr();
          el.innerHTML = `<div class="prev">${arr.map((u, i) => `<figure><img src="${u}"><button data-rm="${i}">×</button></figure>`).join('')}</div><label class="up">+ Subir imagen<input type="file" accept="image/*" class="hidden"></label>${hint ? `<span class="muted" style="margin-left:10px;">${hint}</span>` : ''}`;
          el.querySelectorAll('[data-rm]').forEach((b) => b.addEventListener('click', () => { const a = getArr(); a.splice(+b.dataset.rm, 1); setArr(a); render(); }));
          el.querySelector('input[type=file]').addEventListener('change', async (e) => {
            const f = e.target.files[0]; if (!f) return; toast('Optimizando y subiendo…');
            const url = await uploadImage(f, aspect); if (!url) return;
            let a = getArr(); if (multiple) a.push(url); else a = [url]; setArr(a); render(); toast('Imagen subida');
          });
        }
        render();
      }

      // ---- Login ----
      async function tryLogin(p) {
        const r = await fetch('/api/panel', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ password: p, action: 'login' }) });
        if (r.ok) { const d = await r.json(); if (d.ok) { pass = p; sessionStorage.setItem(KEY, p); showApp(); return true; } }
        return false;
      }
      $('#loginBtn').addEventListener('click', async () => { if (!(await tryLogin($('#pass').value))) $('#loginErr').textContent = 'Contraseña incorrecta.'; });
      $('#pass').addEventListener('keydown', (e) => { if (e.key === 'Enter') $('#loginBtn').click(); });
      $('#logout').addEventListener('click', () => { sessionStorage.removeItem(KEY); location.reload(); });
      $('#pvReload').addEventListener('click', reloadPreview);

      function showApp() { $('#login').classList.add('hidden'); $('#app').classList.remove('hidden'); loadProductos(); loadSitio(); loadVentas(); }

      document.querySelectorAll('.tab').forEach((t) => t.addEventListener('click', () => {
        document.querySelectorAll('.tab').forEach((x) => x.classList.remove('active')); t.classList.add('active');
        $('#tab-productos').classList.toggle('hidden', t.dataset.tab !== 'productos');
        $('#tab-sitio').classList.toggle('hidden', t.dataset.tab !== 'sitio');
        $('#tab-ventas').classList.toggle('hidden', t.dataset.tab !== 'ventas');
        if (t.dataset.tab === 'ventas') loadVentas();
      }));

      // ---- Productos ----
      async function loadProductos() {
        const { ok, data } = await api({ action: 'list' });
        const lista = $('#lista');
        if (!ok) { lista.innerHTML = `<p class="muted">${data.error || 'Error'}</p>`; return; }
        const ps = data.productos || [];
        if (!ps.length) { lista.innerHTML = '<p class="muted">Todavía no hay productos. Creá el primero.</p>'; return; }
        const S = {
          ghost: 'display:inline-flex;align-items:center;background:transparent;color:#eef2ec;border:1.5px solid #3a4c40;border-radius:7px;padding:6px 12px;font-size:12.5px;font-family:inherit;cursor:pointer;',
          danger: 'display:inline-flex;align-items:center;background:transparent;color:#c65b4e;border:1.5px solid #c65b4e;border-radius:7px;padding:6px 12px;font-size:12.5px;font-family:inherit;cursor:pointer;',
        };
        lista.innerHTML = ps.map((p) => `<div class="item">${p.imagenes && p.imagenes[0] ? `<img class="thumb" src="${p.imagenes[0]}">` : '<div class="thumb"></div>'}<div class="info"><div class="name">${p.nombre}</div><div class="muted">$${Number(p.precio).toLocaleString('es-AR')} · stock ${p.stock}</div></div><button style="${S.ghost}" data-edit="${p.slug}">Editar</button><button style="${S.ghost}" data-dup="${p.slug}" title="Duplicar">⧉</button><button style="${S.danger}" data-del="${p.slug}">✕</button></div>`).join('');
        lista.querySelectorAll('[data-edit]').forEach((b) => b.addEventListener('click', () => openP(ps.find((x) => x.slug === b.dataset.edit))));
        lista.querySelectorAll('[data-dup]').forEach((b) => b.addEventListener('click', () => dupP(ps.find((x) => x.slug === b.dataset.dup))));
        lista.querySelectorAll('[data-del]').forEach((b) => b.addEventListener('click', () => delP(b.dataset.del)));

      }
      function setObj() { document.querySelectorAll('#f-objetivos .chip').forEach((c) => c.classList.toggle('on', objSel.has(c.dataset.obj))); }
      function openP(p, isDup) {
        p = p || {}; editSlugOriginal = p.slug || null;
        $('#editorTitle').textContent = isDup ? 'Duplicar producto' : (p.slug ? 'Editar producto' : 'Nuevo producto');
        $('#f-nombre').value = p.nombre || ''; $('#f-slug').value = p.slug || '';
        $('#f-linea').value = p.linea || 'alquimia'; $('#f-tipo').value = p.tipo || 'extracto';
        $('#f-precio').value = p.precio ?? ''; $('#f-stock').value = p.stock ?? 0;
        $('#f-volumen').value = p.volumen || ''; $('#f-graduacion').value = p.graduacion || '';
        $('#f-orden').value = p.orden ?? ''; $('#f-destacado').checked = !!p.destacado;
        $('#f-descCorta').value = p.descripcion_corta || ''; $('#f-momento').value = p.para_que_momento || '';
        $('#f-descLarga').value = p.descripcion_larga || ''; $('#f-ingredientes').value = p.ingredientes || '';
        $('#f-modo').value = p.modo_de_uso || ''; $('#f-proceso').value = p.nuestro_proceso || '';
        $('#f-envio').value = p.envio_y_cuidado || ''; $('#f-advertencias').value = p.advertencias || '';
        $('#f-combina').value = (p.combina_con || []).join(', ');
        const asp = home.imagenAspecto || '1:1';
        prodImgs = [...(p.imagenes || [])]; imgWidget($('#w-prod'), () => prodImgs, (a) => (prodImgs = a), true, prodAspect(), `Formato ${asp} · se recorta y optimiza sola`);
        objSel.clear(); (p.objetivos || []).forEach((o) => objSel.add(o)); setObj();
        $('#editorErr').textContent = ''; $('#editorP').classList.remove('hidden'); $('#editorP').scrollIntoView({ behavior: 'smooth' });
      }
      // "+ Nuevo" abre el selector de plantillas
      $('#nuevo').addEventListener('click', () => {
        $('#editorP').classList.add('hidden');
        const cont = $('#plantillasList');
        cont.innerHTML = PLANTILLAS.map((p, i) => `<span class="chip" data-pl="${i}">${p.label}</span>`).join('') + '<span class="chip" data-pl="-1">⚪ En blanco</span>';
        cont.querySelectorAll('[data-pl]').forEach((c) => c.addEventListener('click', () => {
          const i = +c.dataset.pl;
          $('#plantillas').classList.add('hidden');
          openP(i >= 0 ? { ...PLANTILLAS[i].d } : null);
        }));
        $('#plantillas').classList.remove('hidden');
        $('#plantillas').scrollIntoView({ behavior: 'smooth' });
      });
      $('#cancelar').addEventListener('click', () => $('#editorP').classList.add('hidden'));

      // Duplicar: copia todo, cambia slug y nombre para que sea un producto nuevo.
      function dupP(p) {
        openP({ ...p, slug: (p.slug || '') + '-copia', nombre: (p.nombre || '') + ' (copia)' }, true);
      }
      $('#f-nombre').addEventListener('input', (e) => { if (!editSlugOriginal) $('#f-slug').value = e.target.value.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''); });
      document.querySelectorAll('#f-objetivos .chip').forEach((c) => c.addEventListener('click', () => { const o = c.dataset.obj; objSel.has(o) ? objSel.delete(o) : objSel.add(o); setObj(); }));
      $('#guardar').addEventListener('click', async () => {
        const product = {
          slug: $('#f-slug').value.trim(), nombre: $('#f-nombre').value.trim(), linea: $('#f-linea').value, tipo: $('#f-tipo').value,
          objetivos: [...objSel], precio: parseInt($('#f-precio').value, 10) || 0, stock: parseInt($('#f-stock').value, 10) || 0,
          volumen: $('#f-volumen').value.trim() || null, graduacion: $('#f-graduacion').value.trim() || null,
          orden: $('#f-orden').value ? parseInt($('#f-orden').value, 10) : null, destacado: $('#f-destacado').checked,
          descripcion_corta: $('#f-descCorta').value.trim(), para_que_momento: $('#f-momento').value.trim(), descripcion_larga: $('#f-descLarga').value.trim(),
          ingredientes: $('#f-ingredientes').value.trim(), modo_de_uso: $('#f-modo').value.trim(), nuestro_proceso: $('#f-proceso').value.trim(),
          envio_y_cuidado: $('#f-envio').value.trim(), advertencias: $('#f-advertencias').value.trim(),
          combina_con: $('#f-combina').value.split(',').map((s) => s.trim()).filter(Boolean), imagenes: prodImgs, activo: true,
        };
        if (!product.slug || !product.nombre) { $('#editorErr').textContent = 'Nombre y slug obligatorios.'; return; }
        if (!product.objetivos.length) { $('#editorErr').textContent = 'Elegí al menos un objetivo.'; return; }
        const { ok, data } = await api({ action: 'save', product });
        if (ok) { toast('Guardado'); $('#editorP').classList.add('hidden'); loadProductos(); reloadPreview(); } else $('#editorErr').textContent = data.error || 'Error';
      });
      async function delP(slug) { if (!confirm('¿Borrar producto?')) return; const { ok, data } = await api({ action: 'delete', slug }); if (ok) { toast('Borrado'); loadProductos(); reloadPreview(); } else toast(data.error || 'Error'); }

      // ---- Sitio ----
      async function loadSitio() {
        const { ok, data } = await api({ action: 'getHome' });
        if (ok && data.data) home = Object.assign({ hero: {}, bento: [{}, {}, {}, {}], estrella: {} }, data.data);
        if (!Array.isArray(home.bento)) home.bento = [{}, {}, {}, {}];
        while (home.bento.length < 4) home.bento.push({});
        $('#h-eyebrow').value = home.hero.eyebrow || ''; $('#h-titulo').value = home.hero.titulo || '';
        $('#h-destacada').value = home.hero.destacada || ''; $('#h-lead').value = home.hero.lead || '';
        $('#h-overlay').value = home.hero.overlay ?? ''; $('#h-blur').value = home.hero.blur ?? '';
        $('#s-aspecto').value = home.imagenAspecto || '1:1';
        imgWidget($('#w-hero'), () => (home.hero.imagen ? [home.hero.imagen] : []), (a) => (home.hero.imagen = a[0] || ''), false, 16 / 9, 'Panorámica (16:9)');
        $('#e-eyebrow').value = home.estrella.eyebrow || ''; $('#e-titulo').value = home.estrella.titulo || ''; $('#e-desc').value = home.estrella.desc || '';
        imgWidget($('#w-estrella'), () => (home.estrella.imagen ? [home.estrella.imagen] : []), (a) => (home.estrella.imagen = a[0] || ''), false, 4 / 5, 'Vertical (4:5)');
        // Bento blocks
        const cont = $('#bento-blocks'); cont.innerHTML = '';
        home.bento.forEach((b, i) => {
          const div = document.createElement('div');
          div.style.cssText = 'border-top:1px solid var(--line);padding-top:14px;margin-top:14px;';
          div.innerHTML = `
            <h3 style="margin-top:0">${BENTO_LABELS[i]}</h3>
            <div><label>Título</label><input class="b-tit" value="${(b.titulo || '').replace(/"/g, '&quot;')}"></div>
            <div><label>Subtítulo</label><input class="b-sub" value="${(b.sub || '').replace(/"/g, '&quot;')}"></div>
            <div><label>Foto</label><div class="imgw b-img"></div></div>
          `;
          cont.appendChild(div);
          div.querySelector('.b-tit').addEventListener('input', (e) => (home.bento[i].titulo = e.target.value));
          div.querySelector('.b-sub').addEventListener('input', (e) => (home.bento[i].sub = e.target.value));
          imgWidget(div.querySelector('.b-img'), () => (home.bento[i].imagen ? [home.bento[i].imagen] : []), (a) => (home.bento[i].imagen = a[0] || ''), false, 3 / 2, 'Horizontal (3:2)');
        });
      }
      $('#guardarSitio').addEventListener('click', async () => {
        home.hero.eyebrow = $('#h-eyebrow').value; home.hero.titulo = $('#h-titulo').value;
        home.hero.destacada = $('#h-destacada').value; home.hero.lead = $('#h-lead').value;
        home.imagenAspecto = $('#s-aspecto').value;
        home.hero.overlay = $('#h-overlay').value === '' ? undefined : Number($('#h-overlay').value);
        home.hero.blur = $('#h-blur').value === '' ? undefined : Number($('#h-blur').value);
        home.estrella.eyebrow = $('#e-eyebrow').value; home.estrella.titulo = $('#e-titulo').value; home.estrella.desc = $('#e-desc').value;
        const { ok, data } = await api({ action: 'saveHome', data: home });
        if (ok) { toast('Sitio guardado'); reloadPreview(); } else $('#sitioErr').textContent = data.error || 'Error';
      });

      // ---- Ventas ----
      async function loadVentas() {
        const { ok, data } = await api({ action: 'listOrders' });
        const lista = $('#lista-ventas');
        if (!ok) { lista.innerHTML = `<p class="muted">${data.error || 'Error'}</p>`; return; }
        const os = data.ordenes || [];
        if (!os.length) { lista.innerHTML = '<p class="muted">Aún no se registraron ventas.</p>'; return; }
        
        lista.innerHTML = os.map((o) => {
          const itemsStr = o.items.map((i) => `• ${i.nombre} (x${i.qty})`).join('<br>');
          const fecha = new Date(o.created_at).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
          const badgeColor = o.estado === 'aprobado' ? '#2f4a3a' : o.estado === 'despachado' ? '#6b8469' : '#a87c5a';
          
          return `
            <div class="card" style="margin-bottom:12px;">
              <div class="row" style="justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
                <div>
                  <strong>${o.nombre_cliente}</strong> <span class="muted">(${o.email_cliente})</span>
                  <div class="muted" style="margin-top:2px;">Ref: ${o.external_reference} · ${fecha}</div>
                </div>
                <span class="chip on" style="background:${badgeColor}; border-color:${badgeColor}; pointer-events:none; text-transform:uppercase; font-size:11px;">
                  ${o.estado}
                </span>
              </div>
              <div style="font-size:13px; border-top:1px solid #3a4c40; border-bottom:1px solid #3a4c40; padding:8px 0; margin:8px 0; line-height:1.4;">
                <strong>Items:</strong><br>${itemsStr}
              </div>
              <div class="grid2" style="font-size:13px; margin-bottom:10px;">
                <div><strong>WhatsApp:</strong> <a href="https://wa.me/${o.whatsapp_cliente.replace(/[^0-9]/g, '')}" target="_blank" style="color:#a87c5a;">${o.whatsapp_cliente}</a></div>
                <div><strong>Envío:</strong> ${o.metodo_envio === 'retiro' ? 'Retiro gratis' : `${o.metodo_envio.toUpperCase()} - ${o.direccion}, ${o.localidad}`}</div>
                <div><strong>Productos:</strong> $${Number(o.monto_productos).toLocaleString('es-AR')}</div>
                <div><strong>Envío:</strong> $${Number(o.costo_envio).toLocaleString('es-AR')}</div>
                <div style="grid-column: span 2; font-size:14px; margin-top:4px;"><strong>Total:</strong> $${Number(o.monto_total).toLocaleString('es-AR')}</div>
              </div>
              <div class="row" style="gap:6px;">
                ${o.estado === 'aprobado' ? `<button style="display:inline-flex;align-items:center;background:#2f4a3a;color:#f4f1ea;border:1.5px solid #2f4a3a;border-radius:7px;padding:6px 12px;font-size:12.5px;font-family:inherit;cursor:pointer;" data-ship-id="${o.id}">Marcar Despachado</button>` : ''}
                ${o.estado === 'pendiente' ? `<button style="display:inline-flex;align-items:center;background:transparent;color:#eef2ec;border:1.5px solid #3a4c40;border-radius:7px;padding:6px 12px;font-size:12.5px;font-family:inherit;cursor:pointer;" data-approve-id="${o.id}">Marcar Aprobado (Manual)</button>` : ''}
              </div>
            </div>
          `;
        }).join('');

        lista.querySelectorAll('[data-ship-id]').forEach((b) => b.addEventListener('click', () => changeOrderState(b.dataset.shipId, 'despachado')));
        lista.querySelectorAll('[data-approve-id]').forEach((b) => b.addEventListener('click', () => changeOrderState(b.dataset.approveId, 'aprobado')));
      }

      async function changeOrderState(id, estado) {
        if (!confirm(`¿Cambiar estado de orden a ${estado}?`)) return;
        const { ok, data } = await api({ action: 'updateOrderState', id, estado });
        if (ok) { toast('Orden actualizada'); loadVentas(); } else toast(data.error || 'Error');
      }

      $('#btn-refresh-ventas').addEventListener('click', loadVentas);

      if (pass) tryLogin(pass).then((ok) => { if (!ok) { sessionStorage.removeItem(KEY); pass = ''; } });
    </script>
  </body>
</html>
