# ─────────────────────────────────────────────────────────────
#  Remanso Natural · Variables de entorno
#  Copiá este archivo a ".env" y completá con tus credenciales.
#  NUNCA commitees el archivo .env real.
# ─────────────────────────────────────────────────────────────

# Mercado Pago — Checkout Pro
# Obtené las credenciales en https://www.mercadopago.com.ar/developers/panel
#  · MP_ACCESS_TOKEN es SECRETO (solo servidor). En Netlify se carga como
#    variable de entorno del sitio, no en el código.
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxx-xxxxxxxxx
PUBLIC_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# URL pública del sitio (para back_urls de Mercado Pago)
PUBLIC_SITE_URL=http://localhost:4321

# Contacto (usado en links de WhatsApp y mailto)
PUBLIC_WHATSAPP=5491100000000
PUBLIC_CONTACT_EMAIL=hola@remansonatural.com.ar

# ── Supabase (para el panel de administración — próximo paso) ──
# Creá un proyecto gratis en https://supabase.com
PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyxxxxxxxx
# Clave de servicio (SECRETA, solo para el panel/servidor):
SUPABASE_SERVICE_ROLE_KEY=eyxxxxxxxx
# Clave simple para entrar al panel (elegí una vos):
PANEL_PASSWORD=cambiame

# ── Emails de la compra (Resend — gratis hasta 3.000/mes) ──
# Creá la cuenta en https://resend.com y generá una API key.
RESEND_API_KEY=re_xxxxxxxxxxxx
# Remitente. Sin dominio propio podés usar el de prueba de Resend:
EMAIL_FROM=Remanso Natural <onboarding@resend.dev>
# Tu email: acá te llega el aviso de venta + el mensaje listo para WhatsApp.
EMAIL_OWNER=gonzalolionelprieto@gmail.com
